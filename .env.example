# ========================
# APP
# ========================
NODE_ENV=production
PORT=5000
APP_NAME=url-shortener
BASE_URL=https://yourdomain.com

# ========================
# URL SHORTENER CONFIG
# ========================
SHORT_CODE_LENGTH=6
CUSTOM_ALIAS_ENABLED=true
MAX_URL_LENGTH=2048
DEFAULT_EXPIRY_DAYS=30

# ========================
# DATABASE
# ========================
POSTGRESQL_URL=postgresql://<user>:<password>@<host>:5432/url_shortener
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/url_shortener
MONGODB_LOGS_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/url_logs

# ========================
# REDIS (cache + rate limit)
# ========================
REDIS_URL=redis://<host>:6379
REDIS_TTL=3600

RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=1000

# ========================
# AUTH (JWT)
# ========================
JWT_ACCESS_SECRET=<STRONG_RANDOM_64_CHAR_SECRET>
JWT_REFRESH_SECRET=<STRONG_RANDOM_64_CHAR_SECRET>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ========================
# API KEYS
# ========================
API_KEY_PREFIX=prod
API_KEY_LENGTH=32
API_KEY_HASH_SECRET=<STRONG_RANDOM_SECRET>

# ========================
# SECURITY
# ========================
BCRYPT_SALT_ROUNDS=12

# ========================
# ANALYTICS
# ========================
TRACK_CLICKS=true
GEOIP_API_KEY=<your_geoip_api_key>
USER_AGENT_PARSER=true

# ========================
# STORAGE (S3 / CDN)
# ========================
CDN_BASE_URL=https://cdn.yourdomain.com
AWS_S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=<key>
AWS_SECRET_ACCESS_KEY=<secret>
AWS_REGION=ap-south-1

# ========================
# EMAIL
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sdfsd@gmail.com
SMTP_PASS=sdfsdf
EMAIL_FROM="Shortify <gkrcodersocial@gmail.com>"
EMAIL_PROVIDER=smtp

# ========================
# LOGGING / MONITORING
# ========================
LOG_LEVEL=info
SENTRY_DSN=<your_sentry_dsn>

# ========================
# FEATURES
# ========================
ENABLE_ANALYTICS=true
ENABLE_QR_CODE=true
ENABLE_CUSTOM_DOMAINS=true

# ========================
# DOMAINS
# ========================
ALLOW_CUSTOM_DOMAINS=true
DEFAULT_DOMAIN=yourdomain.com

# ========================
# QUEUE / WORKERS
# ========================
QUEUE_NAME=url-jobs
WORKER_CONCURRENCY=10

# ========================
# ADMIN
# ========================
ADMIN_EMAIL=admin@yourdomain.com
