{
  "name": "url-shortener-backend",
  "version": "1.0.0",
  "description": "Backend for URL shortener SaaS",
  "author": "Gaurav Kesh Roushan",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "predev": "./scripts/start-services.sh",
    "dev": "NODE_ENV=development nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && cp -R src/docs dist/docs",
    "migrate:dev": "NODE_ENV=development tsx src/scripts/migrate.ts",
    "migrate:prod": "NODE_ENV=production tsx src/scripts/migrate.ts",
    "start": "node dist/src/server.js"
  },
  "keywords": [
    "url-shortener",
    "backend",
    "nodejs",
    "typescript"
  ],
  "dependencies": {
    "@upstash/qstash": "^2.11.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv-flow": "^3.3.0",
    "express": "^4.19.2",
    "express-openapi-validator": "^5.5.9",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "ms": "^2.1.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "redis": "^5.11.0",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-mongodb": "^7.0.1",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv-flow": "^3.3.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.6",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
