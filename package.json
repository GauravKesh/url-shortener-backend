{
  "name": "url-shortener-backend",
  "version": "1.0.0",
  "description": "Backend for URL shortener SaaS",
  "author": "Gaurav Kesh Roushan",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && cp -R src/docs dist/docs",
    "start": "node dist/server.js",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "url-shortener",
    "backend",
    "nodejs",
    "typescript"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv-flow": "^3.3.0",
    "express": "^4.19.2",
    "express-openapi-validator": "^5.5.9",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "node-pg-migrate": "^8.0.4",
    "redis": "^5.11.0",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-mongodb": "^7.0.1",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/dotenv-flow": "^3.3.3",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "jest-openapi": "^0.14.2",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
